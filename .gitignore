# Binaries
/bin/
/higgsgo
/higgsgo-cli
*.exe
*.dll
*.so
*.dylib

# Test binaries and coverage
*.test
*.out
coverage.txt
coverage.html

# Go workspace files — go.work is committed (monorepo binding).
# go.work.sum is per-developer.
go.work.sum

# WebUI build output — embedded from source at build time via
# webui/dist/... //go:embed, so committing dist would just duplicate the
# working tree.
webui/dist/

# Claude Code local session state (worktrees, cached agent output).
.claude/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Runtime data
/data/higgsgo.db
/data/higgsgo.db-shm
/data/higgsgo.db-wal
/data/output/

# Local config (secrets)
/configs/higgsgo.local.toml
/configs/higgsgo.prod.toml
/configs/proxies.txt
.env
.env.local

# Node subprocess artifacts (if we keep CloakBrowser bridge)
/node_modules/
package-lock.json

# Logs
*.log
/logs/
